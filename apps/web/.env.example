# Copy to .env.local (gitignored) for local dev, or set as build-time env vars
# in the hosting dashboard for production. Both are read at build time via
# import.meta.env — see src/analytics.ts.

# PostHog project API token. Analytics stay fully disabled (no-op) if unset.
VITE_POSTHOG_KEY=

# Defaults to PostHog's US Cloud host if unset.
VITE_POSTHOG_HOST=https://us.i.posthog.com
