# Board Studio — web app environment.
# Copy to `.env.local` (gitignored) and fill in. All keys are optional:
# with none set, the app runs in local-first mode (no auth, free tier).

# Supabase project credentials — Settings → API in the Supabase dashboard.
# When both are set, the account control becomes active (sign in / sign out).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Dev-only entitlement override for testing Pro/Team gates before Stripe
# billing exists. One of: free | pro | team. Leave empty in normal use.
VITE_DEV_TIER=
